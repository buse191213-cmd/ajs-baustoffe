# PostgreSQL bağlantı dizesi (Neon, Supabase, Railway veya yerel)
DATABASE_URL="postgresql://user:password@localhost:5432/ajs?schema=public"

# Admin oturum cookie'sini imzalamak için. Üret: openssl rand -base64 32
AUTH_SECRET="bunu-uzun-rastgele-bir-dizeyle-degistir"

# Resend e-posta (https://resend.com → API Keys). Boşsa mail atlanır, teklif yine DB'ye yazılır.
RESEND_API_KEY=""
# Doğrulanmış gönderen alan adınız
MAIL_FROM="AJS Baustoffe <noreply@ajsbaustoffe.de>"
# Teklif/iletişim bildirimlerinin gideceği iç adres
MAIL_TO="info@ajsbaustoffe.de"

# İlk admin (seed bunu oluşturur)
SEED_ADMIN_EMAIL="admin@ajsbaustoffe.de"
SEED_ADMIN_PASSWORD="degistir-beni-guclu-bir-sifre"
